# TritonAI Developer API (LiteLLM, OpenAI-compatible). Server-side only.
# Get your key from https://tritonai-api.ucsd.edu/
TRITONAI_API_KEY=
TRITONAI_BASE_URL=https://tritonai-api.ucsd.edu/v1
TRITONAI_MODEL=api-gpt-oss-120b
AI_TIMEOUT_MS=25000

# Optional per-feature model tiers. Both fall back to TRITONAI_MODEL when unset.
# TRITONAI_MODEL_FAST       — tagging (verbatim-grounded classification; cheap is fine).
# TRITONAI_MODEL_REASONING  — journey/friction drafting and friction clustering
#                             (synthesis + root-cause reasoning; a more capable model
#                             supports auto-applying these without per-item review).
TRITONAI_MODEL_FAST=
TRITONAI_MODEL_REASONING=

# GitHub-as-storage. Fine-grained PAT scoped to THIS repo, Contents: read/write.
GITHUB_TOKEN=
GITHUB_REPO=z6johnson/ai-transformation
GITHUB_BRANCH=data

# Identity stamped on saved artifacts and the AI decision log.
PRACTICE_ACTOR=z6johnson@ucsd.edu
